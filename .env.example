# Google OAuth Client ID — create at https://console.cloud.google.com/apis/credentials
# Authorized JS origins: http://localhost:5173, https://your-swa-url.azurestaticapps.net
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Optional: comma-separated list of allowed Google emails (leave empty to allow anyone)
VITE_ALLOWED_EMAILS=

# Optional: Unsplash API access key for random photos
VITE_UNSPLASH_ACCESS_KEY=

# ── Azure Functions (set in Azure SWA Configuration, NOT in .env) ──────────
# These are server-side only — never prefix with VITE_
#
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com   (same as VITE_ value)
# GOOGLE_CLIENT_SECRET=your-client-secret                      (never in browser!)
# COSMOS_CONNECTION_STRING=AccountEndpoint=https://...         (from Cosmos DB portal → Keys)
# COSMOS_DATABASE=PikesFamilyDashboard                         (default used by cosmosClient.ts)
# COSMOS_CONTAINER=dashboard-data                              (default used by cosmosClient.ts)
# APP_URL=https://hub.pikesinternetcafe.com                    (no trailing slash)
